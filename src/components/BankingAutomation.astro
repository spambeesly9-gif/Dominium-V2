---
---

<section class="section banking" id="banking-automation">
  <div class="container">

    <div class="banking-header">
      <div class="badge" style="margin-bottom: var(--sp-4);">AI Banking Automation</div>
      <h2 class="banking-title">Your Condominium Finances,<br />Handled by AI</h2>
      <p class="banking-sub">
        Dominium's AI engine manages the full financial stack for every condominium —
        from provisioning a dedicated IBAN to reconciling every incoming payment,
        automatically and in real time.
      </p>
    </div>

    <div class="banking-grid">

      <!-- IBAN Creation -->
      <div class="banking-card">
        <div class="banking-card__icon">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="2" y="5" width="20" height="14" rx="2"/>
            <line x1="2" y1="10" x2="22" y2="10"/>
            <line x1="6" y1="15" x2="10" y2="15"/>
            <line x1="13" y1="15" x2="16" y2="15"/>
          </svg>
        </div>
        <div class="banking-card__tag">Instant Setup</div>
        <h3 class="banking-card__title">Dedicated IBAN per Condominium</h3>
        <p class="banking-card__desc">
          The moment you add a condominium, Dominium provisions it a dedicated IBAN —
          no bank visits, no paperwork. Resident payments land in the right account
          automatically, correctly attributed from day one.
        </p>
        <ul class="banking-card__list">
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Instant IBAN provisioning
          </li>
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Separate accounts per building
          </li>
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Full transaction visibility
          </li>
        </ul>
      </div>

      <!-- Automated Payables -->
      <div class="banking-card">
        <div class="banking-card__icon">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M15.5 5a7.5 7.5 0 1 0 0 14"/><line x1="3" y1="10" x2="12" y2="10"/><line x1="3" y1="14" x2="12" y2="14"/>
          </svg>
        </div>
        <div class="banking-card__tag">Zero Manual Entry</div>
        <h3 class="banking-card__title">Automated Payables</h3>
        <p class="banking-card__desc">
          Supplier invoices are processed, approved, and paid automatically — allocated
          to the correct condominium with a full audit trail. No spreadsheets, no manual
          bank portal switching, no missed payments.
        </p>
        <ul class="banking-card__list">
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Automated supplier payments
          </li>
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            In-platform approval workflows
          </li>
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Complete payment audit trail
          </li>
        </ul>
      </div>

      <!-- Automated Reconciliation -->
      <div class="banking-card">
        <div class="banking-card__icon">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
          </svg>
        </div>
        <div class="banking-card__tag">AI-Powered</div>
        <h3 class="banking-card__title">Intelligent Reconciliation</h3>
        <p class="banking-card__desc">
          Dominium's AI matches every incoming payment to its contribution record in real
          time. Bank statements reconcile themselves — exceptions are surfaced for review,
          and month-end closes in minutes instead of days.
        </p>
        <ul class="banking-card__list">
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            AI payment matching
          </li>
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Real-time bank reconciliation
          </li>
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Exception flagging &amp; review queue
          </li>
        </ul>
      </div>

    </div>

  </div>
</section>

<style>
  .banking {
    background: var(--white);
    border-top: 1px solid var(--slate-200);
    border-bottom: 1px solid var(--slate-200);
  }

  /* ── Header ─────────────────────────────────────────── */
  .banking-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto var(--sp-12);
  }

  .banking-title {
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    font-weight: 900;
    color: var(--text-dark);
    letter-spacing: -0.035em;
    line-height: 1.12;
    margin-bottom: var(--sp-4);
  }

  .banking-sub {
    font-size: 1.0625rem;
    color: var(--slate-600);
    line-height: 1.75;
  }

  /* ── Cards grid ─────────────────────────────────────── */
  .banking-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-5);
  }

  @media (min-width: 768px) {
    .banking-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* ── Card ───────────────────────────────────────────── */
  .banking-card {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    padding: var(--sp-8);
    background: var(--navy);
    border: 1px solid rgb(255 255 255 / .06);
    border-radius: var(--r-2xl);
    transition: transform var(--t-slow), box-shadow var(--t-slow);
  }

  .banking-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--sh-xl);
  }

  .banking-card__icon {
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgb(227 227 166 / .1);
    border: 1px solid rgb(227 227 166 / .2);
    border-radius: var(--r-xl);
    color: var(--lime);
    flex-shrink: 0;
  }

  .banking-card__tag {
    display: inline-flex;
    width: fit-content;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--lime);
    background: rgb(227 227 166 / .1);
    border: 1px solid rgb(227 227 166 / .2);
    padding: 3px var(--sp-3);
    border-radius: var(--r-full);
  }

  .banking-card__title {
    font-size: 1.125rem;
    font-weight: 800;
    color: var(--white);
    letter-spacing: -0.02em;
    line-height: 1.3;
  }

  .banking-card__desc {
    font-size: 0.9375rem;
    color: rgb(255 255 255 / .6);
    line-height: 1.75;
    flex: 1;
  }

  .banking-card__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    margin-top: var(--sp-2);
    padding-top: var(--sp-4);
    border-top: 1px solid rgb(255 255 255 / .08);
  }

  .banking-card__list li {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: 0.875rem;
    font-weight: 500;
    color: rgb(255 255 255 / .7);
  }

  .banking-card__list li svg {
    color: var(--lime);
    flex-shrink: 0;
  }
</style>
