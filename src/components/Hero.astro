---
---

<section class="hero">
  <div class="container hero-wrap">

    <!-- ── Left: content ─────────────────────────────────── -->
    <div class="hero-content">

      <div class="hero-badge hero-entrance hero-entrance--1">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        AI-Powered · Malta's Condominium Platform
      </div>

      <h1 class="hero-headline hero-entrance hero-entrance--2">
        The Complete Platform for
        <span class="hero-accent">Condominium Administrators</span>
        in Malta
      </h1>

      <p class="hero-sub hero-entrance hero-entrance--3">
        Dominium brings AI-powered automation to Malta's block managers and HOAs —
        from instant IBAN creation and intelligent reconciliation to resident portals
        and accounting integrations, all in one platform.
      </p>

      <div class="hero-cta hero-entrance hero-entrance--4">
        <a href="/contact#demo" class="btn btn--accent btn--lg">
          Book a Demo
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="#how-it-works" class="btn btn--outline btn--lg">
          See How It Works
        </a>
      </div>

    </div>

    <!-- ── Right: dashboard screenshot + cityscape ──────── -->
    <div class="hero-visual hero-entrance hero-entrance--2">
      <div class="hero-image-frame">
        <div class="hero-chrome">
          <div class="hero-chrome-dots">
            <span style="background:#FF5F57"></span>
            <span style="background:#FFBD2E"></span>
            <span style="background:#27C93F"></span>
          </div>
        </div>
        <img
          src="/Images/Home%20Page1.png"
          alt="Dominium condominium management dashboard — Malta"
          class="hero-img"
          loading="eager"
          decoding="async"
          fetchpriority="high"
          width="1400"
          height="900"
        />
      </div>
    </div>
  </div>

  <!-- Integrations strip -->
  <div class="integ-strip">
    <div class="container integ-strip-inner">
      <span class="integ-label">Integrates with</span>

      <div class="integ-group">
        <span class="integ-group-label">Accounting</span>
        <div class="integ-logos">
          <img src="/Xero%20logo.webp" alt="Xero" class="integ-logo" />
          <div class="integ-sep" aria-hidden="true"></div>
          <img src="/Quickbooks%20logo.png" alt="QuickBooks" class="integ-logo" />
          <div class="integ-sep" aria-hidden="true"></div>
          <img src="/Zoho%20logo.webp" alt="Zoho Books" class="integ-logo" />
        </div>
      </div>

      <div class="integ-divider" aria-hidden="true"></div>

      <div class="integ-group">
        <span class="integ-group-label">Banking</span>
        <div class="integ-logos">
          <img src="/Fyorin%20logo.webp" alt="Fyorin" class="integ-logo" />
          <div class="integ-sep" aria-hidden="true"></div>
          <img src="/Revolut%20logo.webp" alt="Revolut" class="integ-logo" />
        </div>
      </div>
    </div>
  </div>

</section>


<style>
  /* ── Section — shader gradient background ───────────── */
  .hero {
    position: relative;
    overflow: visible; /* spotlight self-clips; visible lets image frame scale on hover */
    border-bottom: 1px solid var(--slate-100);
  }

  /* Ensure all direct children of hero sit above the gradient */
  .hero > :not(:first-child) {
    position: relative;
    z-index: 1;
  }

  /* ── Two-column layout ───────────────────────────────── */
  .hero-wrap {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-12);
    padding-top: var(--sp-16);
    padding-bottom: var(--sp-10);
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-wrap {
      grid-template-columns: 3fr 8fr;
      gap: var(--sp-12);
      padding-top: var(--sp-16);
      padding-bottom: 0;
      align-items: stretch;
    }
  }

  /* ── Badge ───────────────────────────────────────────── */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-4);
    background: var(--navy-50);
    color: var(--navy);
    border: 1px solid var(--navy-100);
    border-radius: var(--r-full);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: var(--sp-6);
  }

  /* ── Headline ────────────────────────────────────────── */
  .hero-headline {
    font-size: clamp(2rem, 4vw, 3.125rem);
    font-weight: 800;
    color: var(--text-dark);
    line-height: 1.12;
    letter-spacing: -0.035em;
    -webkit-text-stroke: 0.5px var(--text-dark);
    margin-bottom: var(--sp-6);
  }

  .hero-accent { color: var(--navy); }

  /* ── Sub-text ────────────────────────────────────────── */
  .hero-sub {
    font-size: 1.0625rem;
    color: var(--slate-600);
    line-height: 1.8;
    margin-bottom: var(--sp-8);
    max-width: 480px;
  }

  /* ── CTA buttons ─────────────────────────────────────── */
  .hero-cta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-3);
    margin-bottom: var(--sp-8);
  }

  /* ── Hero visual — dashboard screenshot ─────────────── */
  .hero-visual {
    min-width: 0;
    align-self: stretch;
    margin-top: var(--sp-10);
    display: flex;
    flex-direction: column;
  }

  .hero-image-frame {
    border-radius: var(--r-2xl);
    overflow: hidden;
    border: 1px solid var(--slate-200);
    box-shadow: var(--sh-2xl), 0 0 0 1px var(--slate-100);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
    transform-style: preserve-3d;
    will-change: transform;
  }

  .hero-image-frame:hover {
    transform: perspective(1200px) rotateY(-4deg) rotateX(2deg);
    box-shadow: 20px 30px 60px -12px rgb(0 4 53 / .22), 0 0 0 1px var(--navy-100);
  }

  .hero-chrome {
    display: flex;
    align-items: center;
    padding: 0.55rem var(--sp-4);
    background: var(--slate-100);
    border-bottom: 1px solid var(--slate-200);
  }

  .hero-chrome-dots {
    display: flex;
    gap: 5px;
  }

  .hero-chrome-dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: block;
  }

  .hero-img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Integrations strip ───────────────────────────────── */
  .integ-strip {
    border-top: 1px solid var(--slate-100);
    background: var(--bg-light);
    padding: var(--sp-5) 0;
  }

  .integ-strip-inner {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-5) var(--sp-8);
  }

  .integ-label {
    font-size: 0.8125rem;
    color: var(--slate-400);
    font-weight: 600;
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }

  .integ-group {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .integ-group-label {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--slate-400);
  }

  .integ-logos {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-4);
  }

  .integ-logo {
    height: 28px;
    width: auto;
    display: block;
  }

  .integ-sep {
    width: 1px;
    height: 1.25rem;
    background: var(--slate-200);
    flex-shrink: 0;
  }

  .integ-divider {
    width: 1px;
    height: 3rem;
    background: var(--slate-200);
    flex-shrink: 0;
    align-self: center;
  }

  /* ── Hero entrance animations ───────────────────────── */
  .hero-entrance {
    animation: heroEntrance 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .hero-entrance--1 { animation-delay: 0.05s; }
  .hero-entrance--2 { animation-delay: 0.15s; }
  .hero-entrance--3 { animation-delay: 0.25s; }
  .hero-entrance--4 { animation-delay: 0.35s; }
  .hero-entrance--5 { animation-delay: 0.44s; }

  /* ── Mobile ──────────────────────────────────────────── */
  @media (max-width: 640px) {
    .hero-wrap { padding-top: var(--sp-12); }
    .hero-headline { font-size: 1.875rem; }
    .hero-sub { max-width: 100%; }
  }
</style>
