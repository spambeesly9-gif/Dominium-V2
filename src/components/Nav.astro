---
const currentPath = Astro.url.pathname;

const featuresCategories = [
  {
    slug: 'admin',
    label: 'Admin Panel',
    icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>',
    desc: 'Blocks, units, fees & maintenance',
    subItems: [
      { label: 'Block Management', href: '/features/admin/block-management' },
      { label: 'Unit & Client Management', href: '/features/admin/unit-client-management' },
      { label: 'Contribution Fees', href: '/features/admin/contribution-fees' },
      { label: 'Maintenance Requests', href: '/features/admin/maintenance-work-requests' },
      { label: 'Document Management', href: '/features/admin/document-management' },
    ],
  },
  {
    slug: 'client-portal',
    label: 'Client Portal',
    icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>',
    desc: 'Self-service portal for residents',
    subItems: [
      { label: 'Issue Reporting', href: '/features/client-portal/issue-reporting' },
      { label: 'Live Balance', href: '/features/client-portal/live-balance' },
      { label: 'Online Payments', href: '/features/client-portal/online-payments' },
      { label: 'Mobile App', href: '/features/client-portal/mobile-app' },
    ],
  },
  {
    slug: 'accounting',
    label: 'Accounting',
    icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>',
    desc: 'Xero, QuickBooks & Zoho integrations',
    subItems: [
      { label: 'Xero Integration', href: '/features/accounting/xero' },
      { label: 'QuickBooks Integration', href: '/features/accounting/quickbooks' },
      { label: 'Zoho Books Integration', href: '/features/accounting/zoho-books' },
      { label: 'Financial Reporting', href: '/features/accounting/financial-reporting' },
      { label: 'Contribution Invoicing', href: '/features/accounting/contribution-invoicing' },
    ],
  },
  {
    slug: 'banking',
    label: 'Banking',
    icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>',
    desc: 'Fyorin IBAN & virtual accounts',
    subItems: [
      { label: 'Fyorin Virtual Banking', href: '/features/banking/fyorin' },
      { label: 'Virtual IBAN per Block', href: '/features/banking/virtual-iban' },
      { label: 'Automated Payments', href: '/features/banking/automated-payments' },
      { label: 'Payment Tracking', href: '/features/banking/payment-tracking' },
    ],
  },
];

const featuresActive = currentPath.startsWith('/features');
---

<header class="nav-wrapper" id="nav">
  <div class="container nav-inner">

    <!-- Logo -->
    <a href="/" class="nav-logo" aria-label="Dominium home">
      <img src="/Logo.png" alt="Dominium" class="nav-logo__img" />
    </a>

    <!-- Desktop nav -->
    <nav class="nav-links hide-mobile" aria-label="Main navigation">

      <!-- Features with mega-menu -->
      <div class="nav-item nav-item--dropdown">
        <a
          href="/features"
          class={`nav-link nav-link--has-arrow ${featuresActive ? 'nav-link--active' : ''}`}
          {...(featuresActive ? { 'aria-current': 'page' } : {})}
        >
          Features
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="nav-chevron" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
        </a>

        <!-- Mega-menu dropdown -->
        <div class="nav-mega">
          <div class="mega-inner">
            {featuresCategories.map(cat => (
              <div class="mega-col">
                <a href={`/features/${cat.slug}`} class="mega-col-head">
                  <span class="mega-col-icon" set:html={cat.icon} />
                  <span class="mega-col-info">
                    <span class="mega-col-title">{cat.label}</span>
                    <span class="mega-col-desc">{cat.desc}</span>
                  </span>
                </a>
                <ul class="mega-list">
                  {cat.subItems.map(item => (
                    <li>
                      <a href={item.href} class="mega-link">{item.label}</a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
          <div class="mega-footer">
            <a href="/features" class="mega-footer-link">
              View all features
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>

      <a href="/pricing"  class={`nav-link ${currentPath === '/pricing'  ? 'nav-link--active' : ''}`} {...(currentPath === '/pricing'  ? { 'aria-current': 'page' } : {})}>Pricing</a>
      <a href="/insights" class={`nav-link ${currentPath.startsWith('/insights') ? 'nav-link--active' : ''}`} {...(currentPath.startsWith('/insights') ? { 'aria-current': 'page' } : {})}>Insights</a>
      <a href="/contact"  class={`nav-link ${currentPath === '/contact'  ? 'nav-link--active' : ''}`} {...(currentPath === '/contact'  ? { 'aria-current': 'page' } : {})}>Contact</a>
    </nav>

    <!-- Desktop CTA -->
    <div class="nav-actions hide-mobile">
      <a href="/contact#demo" class="nav-cta">Get Started</a>
    </div>

    <!-- Mobile hamburger -->
    <button
      class="nav-hamburger hide-desktop"
      id="nav-toggle"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobile-menu" role="navigation" aria-label="Mobile navigation">
    <div class="mobile-menu__inner">
      <a href="/features" class="mobile-link">Features</a>
      <div class="mobile-sub">
        {featuresCategories.map(cat => (
          <a href={`/features/${cat.slug}`} class="mobile-sub-link">{cat.label}</a>
        ))}
      </div>
      <a href="/pricing"  class="mobile-link">Pricing</a>
      <a href="/insights" class="mobile-link">Insights</a>
      <a href="/contact"  class="mobile-link">Contact</a>
      <div class="mobile-menu__actions">
        <a href="/contact#demo" class="mobile-cta">Get Started</a>
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu   = document.getElementById('mobile-menu');
  const nav    = document.getElementById('nav');

  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(open));
    toggle.classList.toggle('is-open', open ?? false);
  });

  document.addEventListener('click', (e) => {
    if (menu?.classList.contains('is-open') && !nav?.contains(e.target as Node)) {
      menu.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.classList.remove('is-open');
    }
  });

  const header = document.getElementById('nav');
  const onScroll = () => header?.classList.toggle('nav--scrolled', window.scrollY > 12);
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // ── Dropdown hover fix ──────────────────────────────────
  // JS-managed hover prevents the CSS gap between trigger and
  // panel from causing the menu to close mid-transition.
  const dropdownEl = document.querySelector('.nav-item--dropdown') as HTMLElement | null;
  let closeTimer: ReturnType<typeof setTimeout> | null = null;

  dropdownEl?.addEventListener('mouseenter', () => {
    if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
    dropdownEl.classList.add('is-hovered');
  });

  dropdownEl?.addEventListener('mouseleave', () => {
    closeTimer = setTimeout(() => {
      dropdownEl.classList.remove('is-hovered');
      closeTimer = null;
    }, 160);
  });
</script>

<style>
  /* ── Wrapper ─────────────────────────────────────────── */
  .nav-wrapper {
    position: sticky;
    top: 0;
    z-index: 200;
    background: var(--navy);
    border-bottom: 1px solid rgb(255 255 255 / .08);
    transition: box-shadow var(--t-base), border-color var(--t-base);
  }
  .nav-wrapper.nav--scrolled {
    box-shadow: 0 2px 24px -4px rgb(0 0 0 / .5);
    border-bottom-color: rgb(255 255 255 / .12);
  }

  /* ── Inner ───────────────────────────────────────────── */
  .nav-inner {
    display: flex;
    align-items: center;
    height: 4.25rem;
    gap: var(--sp-8);
  }

  /* ── Logo ────────────────────────────────────────────── */
  .nav-logo { display: flex; align-items: center; flex-shrink: 0; }
  .nav-logo__img {
    height: 38px;
    width: auto;
    display: block;
    object-fit: contain;
    filter: brightness(0) invert(1);
    opacity: 0.95;
    transition: opacity var(--t-fast);
  }
  .nav-logo:hover .nav-logo__img { opacity: 1; }

  /* ── Nav links row ───────────────────────────────────── */
  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--sp-1);
    margin-left: auto;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: var(--sp-2) var(--sp-3);
    font-size: 0.9375rem;
    font-weight: 500;
    color: rgb(255 255 255 / .72);
    border-radius: var(--r-md);
    transition: color var(--t-fast), background var(--t-fast);
    white-space: nowrap;
  }
  .nav-link:hover { color: var(--white); background: rgb(255 255 255 / .08); }
  .nav-link--active { color: var(--lime); font-weight: 600; }

  .nav-chevron {
    transition: transform var(--t-base);
    flex-shrink: 0;
  }

  /* ── Dropdown item wrapper ───────────────────────────── */
  /* Static so the mega menu escapes and anchors to nav-wrapper */
  .nav-item { position: static; }
  .nav-item--dropdown { position: static; }

  /* ── Mega-menu — full width ──────────────────────────── */
  .nav-mega {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background: #ffffff;
    border-top: 1px solid var(--slate-200);
    border-bottom: 1px solid var(--slate-200);
    box-shadow: 0 24px 64px -12px rgb(0 0 0 / .22), 0 8px 20px -4px rgb(0 0 0 / .08);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(-4px);
    /* Close: delay 150ms so cursor has time to reach dropdown */
    transition: opacity 0.18s ease 0.15s, transform 0.18s ease 0.15s, visibility 0.18s 0.15s;
    z-index: 300;
  }

  .nav-item--dropdown.is-hovered .nav-mega,
  .nav-item--dropdown:focus-within .nav-mega {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
    /* Open: no delay — appears immediately */
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s;
  }

  .nav-item--dropdown.is-hovered .nav-chevron,
  .nav-item--dropdown:focus-within .nav-chevron {
    transform: rotate(180deg);
  }

  /* Centred content wrapper inside full-width panel */
  .mega-inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-2);
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--sp-8) var(--sp-6) var(--sp-6);
  }

  .mega-col {
    padding: var(--sp-4) var(--sp-5);
    border-right: 1px solid var(--slate-100);
  }
  .mega-col:last-child { border-right: none; }

  /* Category head */
  .mega-col-head {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-4);
    padding: var(--sp-3) var(--sp-3) var(--sp-4);
    border-radius: var(--r-xl);
    transition: background var(--t-fast);
    margin-bottom: var(--sp-3);
  }
  .mega-col-head:hover { background: var(--bg-light); }

  .mega-col-icon {
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--navy);
    color: var(--lime);
    border-radius: var(--r-lg);
    flex-shrink: 0;
  }

  .mega-col-info { display: flex; flex-direction: column; gap: 3px; }

  .mega-col-title {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--navy);
    line-height: 1.2;
  }

  .mega-col-desc {
    font-size: 0.8125rem;
    color: var(--slate-400);
    line-height: 1.4;
  }

  /* Sub-items list */
  .mega-list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }

  .mega-link {
    display: block;
    padding: var(--sp-2) var(--sp-3);
    font-size: 0.875rem;
    color: var(--slate-600);
    border-radius: var(--r-lg);
    transition: color var(--t-fast), background var(--t-fast);
    line-height: 1.45;
    font-weight: 450;
  }
  .mega-link:hover {
    color: var(--navy);
    background: var(--navy-50);
    font-weight: 500;
  }

  /* Mega footer */
  .mega-footer {
    border-top: 1px solid var(--slate-100);
    background: var(--bg-light);
  }

  .mega-footer-link {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--navy);
    transition: color var(--t-fast);
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--sp-4) calc(var(--sp-6) + var(--sp-5));
  }
  .mega-footer-link:hover { color: var(--navy-700); }

  /* ── Actions ─────────────────────────────────────────── */
  .nav-actions { display: flex; align-items: center; gap: var(--sp-3); flex-shrink: 0; }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.5625rem 1.125rem;
    background: var(--lime);
    color: var(--navy);
    border-radius: var(--r-lg);
    font-size: 0.9375rem;
    font-weight: 700;
    transition: all var(--t-base);
    white-space: nowrap;
    position: relative;
    overflow: hidden;
  }
  .nav-cta::after {
    content: '';
    position: absolute;
    top: -50%; left: -70%;
    width: 45%; height: 200%;
    background: linear-gradient(to right, transparent, rgba(255,255,255,0.4), transparent);
    transform: skewX(-20deg);
    transition: left 0.5s ease;
    pointer-events: none;
  }
  .nav-cta:hover {
    background: var(--lime-dark);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px -2px rgb(227 227 166 / .4);
  }
  .nav-cta:hover::after { left: 130%; }

  /* ── Hamburger ───────────────────────────────────────── */
  .nav-hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.5rem;
    height: 2.5rem;
    padding: var(--sp-2);
    margin-left: auto;
    border-radius: var(--r-md);
    cursor: pointer;
    background: none;
    border: none;
    transition: background var(--t-fast);
  }
  .nav-hamburger:hover { background: rgb(255 255 255 / .1); }
  .nav-hamburger span {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--white);
    border-radius: 2px;
    transition: all var(--t-base);
    transform-origin: center;
  }
  .nav-hamburger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-hamburger.is-open span:nth-child(2) { opacity: 0; }
  .nav-hamburger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ── Mobile menu ─────────────────────────────────────── */
  .mobile-menu {
    display: none;
    overflow: hidden;
    background: var(--navy);
    border-top: 1px solid rgb(255 255 255 / .08);
  }
  .mobile-menu.is-open { display: block; }

  .mobile-menu__inner {
    padding: var(--sp-4) var(--sp-6) var(--sp-6);
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }

  .mobile-link {
    display: block;
    padding: var(--sp-3) var(--sp-4);
    font-size: 1rem;
    font-weight: 500;
    color: rgb(255 255 255 / .7);
    border-radius: var(--r-lg);
    transition: background var(--t-fast), color var(--t-fast);
  }
  .mobile-link:hover { background: rgb(255 255 255 / .08); color: var(--white); }

  .mobile-sub {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-left: var(--sp-4);
    border-left: 2px solid rgb(255 255 255 / .1);
    margin-left: var(--sp-4);
    margin-bottom: var(--sp-2);
  }

  .mobile-sub-link {
    display: block;
    padding: var(--sp-2) var(--sp-3);
    font-size: 0.875rem;
    color: rgb(255 255 255 / .5);
    border-radius: var(--r-md);
    transition: color var(--t-fast);
  }
  .mobile-sub-link:hover { color: var(--lime); }

  .mobile-menu__actions {
    margin-top: var(--sp-4);
    padding-top: var(--sp-4);
    border-top: 1px solid rgb(255 255 255 / .08);
  }

  .mobile-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--sp-3) var(--sp-4);
    background: var(--lime);
    border-radius: var(--r-lg);
    font-size: 1rem;
    font-weight: 700;
    color: var(--navy);
    transition: background var(--t-fast);
  }
  .mobile-cta:hover { background: var(--lime-dark); }

  @media (max-width: 768px) {
    .nav-links  { display: none; }
    .nav-actions { display: none; }
  }
</style>
