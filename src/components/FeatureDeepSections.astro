---
const { feature, categorySlug, categoryTitle } = Astro.props;

// Cycling panel icons (SVG inner paths only)
const icons = [
  // Settings / setup
  `<path d="M12 15a3 3 0 100-6 3 3 0 000 6z"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/>`,
  // Check circle / done
  `<path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>`,
  // Eye / transparency
  `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>`,
  // Bar chart / analytics
  `<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>`,
  // Zap / automation
  `<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>`,
];
---

{feature.sections && feature.sections.length > 0 && (
  <section class="sf-deep">
    <div class="container">
      <div class="sf-deep-intro">
        <div class="badge">In Depth</div>
        <h2 class="sf-deep-intro__title">How {feature.title} Works</h2>
        <p class="sf-deep-intro__sub">A closer look at what's under the hood.</p>
      </div>

      {feature.sections.map((s, i) => (
        <div class={`sf-deep-row ${i % 2 === 1 ? 'sf-deep-row--flip' : ''}`} data-reveal>

          <div class="sf-deep-content">
            <div class="sf-deep-num">{String(i + 1).padStart(2, '0')}</div>
            <h3 class="sf-deep-heading">{s.heading}</h3>
            <p class="sf-deep-body">{s.body}</p>
          </div>

          <div class="sf-deep-panel" aria-hidden="true">
            <div class="sf-deep-card">
              <div class="sf-deep-card__glow"></div>
              <div class="sf-deep-card__corner-dot"></div>
              <svg
                class="sf-deep-card__icon"
                width="72"
                height="72"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.25"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={icons[i % icons.length]}
              />
              <p class="sf-deep-card__label">{s.heading}</p>
            </div>
          </div>

        </div>
      ))}
    </div>
  </section>
)}

<!-- Bottom CTA -->
<section class="sf-bottom-cta">
  <div class="container sf-bottom-cta-inner">
    <div>
      <h2 class="sf-bottom-cta__title">Ready to see {feature.title} in action?</h2>
      <p class="sf-bottom-cta__sub">Book a free demo and we'll walk you through everything Dominium can do for your portfolio.</p>
    </div>
    <a href="/contact#demo" class="btn btn--accent btn--lg">
      Book a Free Demo
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
</section>

<script>
  const els = document.querySelectorAll('[data-reveal]');
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('revealed');
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.12 });
  els.forEach(el => io.observe(el));
</script>

<style>
  /* ── Deep sections wrapper ──────────────────────────────── */
  .sf-deep {
    background: var(--bg-light);
    border-top: 1px solid var(--slate-200);
    padding: var(--sp-20) 0 var(--sp-8);
  }

  /* Section intro */
  .sf-deep-intro {
    text-align: center;
    margin-bottom: var(--sp-16);
  }

  .sf-deep-intro__title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 900;
    color: var(--text-dark);
    letter-spacing: -0.035em;
    line-height: 1.15;
    margin-top: var(--sp-4);
    margin-bottom: var(--sp-3);
  }

  .sf-deep-intro__sub {
    font-size: 1.0625rem;
    color: var(--slate-500);
  }

  /* Alternating row */
  .sf-deep-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-10);
    align-items: center;
    padding: var(--sp-14) 0;
    border-bottom: 1px solid var(--slate-200);
  }

  .sf-deep-row:last-child {
    border-bottom: none;
  }

  @media (min-width: 768px) {
    .sf-deep-row {
      grid-template-columns: 1fr 1fr;
      gap: var(--sp-20);
    }
    .sf-deep-row--flip .sf-deep-panel {
      order: -1;
    }
  }

  /* Reveal animation */
  [data-reveal] {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s cubic-bezier(.22,1,.36,1), transform 0.6s cubic-bezier(.22,1,.36,1);
  }

  [data-reveal].revealed {
    opacity: 1;
    transform: none;
  }

  /* Content side */
  .sf-deep-num {
    font-size: clamp(3.5rem, 7vw, 6rem);
    font-weight: 900;
    line-height: 1;
    color: var(--lime);
    opacity: 0.3;
    margin-bottom: var(--sp-4);
    letter-spacing: -0.04em;
    font-variant-numeric: tabular-nums;
    display: block;
  }

  .sf-deep-heading {
    font-size: clamp(1.375rem, 2.5vw, 1.875rem);
    font-weight: 800;
    color: var(--text-dark);
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin-bottom: var(--sp-5);
  }

  .sf-deep-body {
    font-size: 1.0625rem;
    color: var(--slate-600);
    line-height: 1.8;
    max-width: 480px;
  }

  /* Panel side */
  .sf-deep-panel {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .sf-deep-card {
    width: 100%;
    max-width: 380px;
    min-height: 260px;
    background: linear-gradient(145deg, var(--navy) 0%, #001180 55%, #000a52 100%);
    border-radius: var(--r-2xl);
    padding: var(--sp-10) var(--sp-8);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-end;
    gap: var(--sp-4);
    box-shadow: 0 24px 60px rgba(0,4,53,.25), 0 0 0 1px rgba(255,255,255,.06);
    position: relative;
    overflow: hidden;
  }

  .sf-deep-card__glow {
    position: absolute;
    top: -50px;
    right: -50px;
    width: 180px;
    height: 180px;
    background: radial-gradient(circle, rgba(227,227,166,.28) 0%, transparent 65%);
    pointer-events: none;
  }

  .sf-deep-card__corner-dot {
    position: absolute;
    top: var(--sp-5);
    right: var(--sp-5);
    width: 8px;
    height: 8px;
    background: var(--lime);
    border-radius: 50%;
    opacity: 0.6;
  }

  .sf-deep-card__icon {
    color: rgba(227, 227, 166, 0.7);
    position: relative;
    z-index: 1;
    flex-shrink: 0;
  }

  .sf-deep-card__label {
    font-size: 1rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.35;
    position: relative;
    z-index: 1;
    max-width: 260px;
  }

  /* ── Bottom CTA ─────────────────────────────────────────── */
  .sf-bottom-cta {
    background: var(--navy);
    padding: var(--sp-16) 0;
  }

  .sf-bottom-cta-inner {
    display: flex;
    flex-direction: column;
    gap: var(--sp-8);
    align-items: flex-start;
  }

  @media (min-width: 768px) {
    .sf-bottom-cta-inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: var(--sp-12);
    }
  }

  .sf-bottom-cta__title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 900;
    color: #ffffff;
    letter-spacing: -0.035em;
    margin-bottom: var(--sp-3);
  }

  .sf-bottom-cta__sub {
    font-size: 1rem;
    color: rgb(255 255 255 / .6);
    max-width: 520px;
    line-height: 1.7;
  }
</style>
