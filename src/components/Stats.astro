---
---

<section class="stats-section" id="stats" aria-label="Platform statistics">
  <div class="container stats-inner">

    <div class="stat-item">
      <span class="stat-num" data-target="800" data-suffix="+">0</span>
      <span class="stat-label">Blocks Managed</span>
    </div>

    <div class="stat-div" aria-hidden="true"></div>

    <div class="stat-item">
      <span class="stat-num" data-target="5000" data-suffix="+" data-comma="true">0</span>
      <span class="stat-label">Users Onboarded</span>
    </div>

    <div class="stat-div" aria-hidden="true"></div>

    <div class="stat-item">
      <span class="stat-num" data-target="94" data-suffix="%">0</span>
      <span class="stat-label">Avg. Collection Rate</span>
    </div>

    <div class="stat-div" aria-hidden="true"></div>

    <div class="stat-item">
      <span class="stat-num" data-target="99.9" data-suffix="%" data-decimal="true">0</span>
      <span class="stat-label">Uptime SLA</span>
    </div>

  </div>
</section>

<script>
  const SHUTTER_DURATION = 900;   // ms of random flickering
  const COUNT_DURATION   = 700;   // ms of counting up after shutter
  const SHUTTER_FPS      = 18;    // how many random flickers per second

  function formatNum(value: number, useComma: boolean, isDecimal: boolean): string {
    if (isDecimal) return value.toFixed(1);
    const int = Math.floor(value);
    return useComma ? int.toLocaleString('en') : String(int);
  }

  function animateStat(el: HTMLElement) {
    const target   = parseFloat(el.dataset.target ?? '0');
    const suffix   = el.dataset.suffix ?? '';
    const useComma = el.dataset.comma === 'true';
    const isDecimal = el.dataset.decimal === 'true';

    let shutterTimer: ReturnType<typeof setInterval> | null = null;
    let startTime: number | null = null;

    // Phase 1 — shutter: rapid random numbers
    shutterTimer = setInterval(() => {
      const rand = isDecimal
        ? (Math.random() * target * 1.3)
        : Math.floor(Math.random() * target * 1.3);
      el.textContent = formatNum(rand as number, useComma, isDecimal) + suffix;
    }, 1000 / SHUTTER_FPS);

    setTimeout(() => {
      if (shutterTimer !== null) clearInterval(shutterTimer);

      // Phase 2 — count up: ease-out from 0 to target
      function countUp(timestamp: number) {
        if (!startTime) startTime = timestamp;
        const elapsed  = timestamp - startTime;
        const progress = Math.min(elapsed / COUNT_DURATION, 1);
        // ease-out cubic
        const eased    = 1 - Math.pow(1 - progress, 3);
        const current  = isDecimal
          ? eased * target
          : Math.floor(eased * target);

        el.textContent = formatNum(current as number, useComma, isDecimal) + suffix;

        if (progress < 1) {
          requestAnimationFrame(countUp);
        } else {
          el.textContent = formatNum(target, useComma, isDecimal) + suffix;
        }
      }

      requestAnimationFrame(countUp);
    }, SHUTTER_DURATION);
  }

  function init() {
    const nums = document.querySelectorAll<HTMLElement>('.stat-num[data-target]');
    if (!nums.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            animateStat(entry.target as HTMLElement);
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.6 }
    );

    nums.forEach((el) => observer.observe(el));
  }

  // Run after DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>

<style>
  .stats-section {
    background: var(--navy);
    border-top: 1px solid rgb(255 255 255 / .06);
    border-bottom: 1px solid rgb(255 255 255 / .06);
    padding: var(--sp-12) 0;
  }

  .stats-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--sp-8) var(--sp-16);
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-2);
  }

  .stat-num {
    font-size: clamp(2.25rem, 4vw, 3rem);
    font-weight: 900;
    color: var(--lime);
    letter-spacing: -0.05em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
    min-width: 5ch;
    text-align: center;
    display: block;
  }

  .stat-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: rgb(255 255 255 / .5);
    text-align: center;
    letter-spacing: 0.01em;
  }

  .stat-div {
    width: 1px;
    height: 3rem;
    background: rgb(255 255 255 / .1);
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .stat-div { display: none; }
    .stats-inner { gap: var(--sp-8); }
  }
</style>
