---
---

<section class="final-cta" aria-label="Call to action">

  <!-- Animated background (consistent with hero) -->
  <div class="cta-bg" aria-hidden="true">
    <div class="cta-blob cta-blob--1"></div>
    <div class="cta-blob cta-blob--2"></div>
    <div class="cta-grid"></div>
  </div>

  <div class="container cta-inner">

    <!-- Content -->
    <div class="cta-content">
      <div class="cta-badge">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        Quick onboarding &middot; No setup fee
      </div>

      <h2 class="cta-headline">
        Ready to Modernise Your<br />
        <span class="cta-accent">Condominium Management?</span>
      </h2>

      <p class="cta-sub">
        Join Malta's block managers and HOAs on Dominium. Book a personalised demo and see exactly how it fits your portfolio — no commitment required.
      </p>

      <div class="cta-buttons">
        <a href="/contact#demo" class="btn btn--accent btn--lg">
          Book a Free Demo
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/pricing" class="btn btn--ghost-light btn--lg">
          View Pricing
        </a>
      </div>

      <div class="cta-trust">
        <div class="cta-trust-item">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          No setup fee
        </div>
        <div class="cta-trust-item">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Cancel anytime
        </div>
        <div class="cta-trust-item">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Dedicated support team
        </div>
        <div class="cta-trust-item">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Built for Malta administrators
        </div>
      </div>
    </div>

    <!-- Pricing preview card -->
    <div class="cta-visual">
      <div class="pricing-preview">
        <div class="pp-header">
          <span class="pp-label">Plans starting from</span>
          <div class="pp-price">
            <span class="pp-currency">€</span>
            <span class="pp-amount">300</span>
            <span class="pp-period">/month</span>
          </div>
          <span class="pp-sub">No hidden fees &middot; Cancel anytime</span>
        </div>

        <div class="pp-tiers">
          <div class="pp-tier">
            <div class="pp-tier-left">
              <span class="pp-tier-name">Beginner</span>
              <span class="pp-tier-desc">Up to 300 units</span>
            </div>
            <span class="pp-tier-price">€300/mo</span>
          </div>
          <div class="pp-tier pp-tier--featured">
            <div class="pp-tier-left">
              <span class="pp-tier-name">Professional</span>
              <span class="pp-tier-desc">Up to 800 units · Accounting</span>
            </div>
            <div class="pp-tier-right">
              <span class="pp-tier-badge">Popular</span>
              <span class="pp-tier-price">€500/mo</span>
            </div>
          </div>
          <div class="pp-tier">
            <div class="pp-tier-left">
              <span class="pp-tier-name">Enterprise</span>
              <span class="pp-tier-desc">Up to 2,000 units · Banking</span>
            </div>
            <span class="pp-tier-price">€800/mo</span>
          </div>
        </div>

        <a href="/pricing" class="pp-cta-link">
          Compare all plans
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <div class="neural-badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M8 12l3 3 5-5"/></svg>
        Built by Neural AI &middot; Made in Malta
      </div>
    </div>

  </div>
</section>

<style>
  /* ── Section ─────────────────────────────────────────── */
  .final-cta {
    background: #000435;
    position: relative;
    overflow: hidden;
    padding: var(--sp-24) 0;
  }

  /* ── Background ──────────────────────────────────────── */
  .cta-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .cta-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgb(255 255 255 / .025) 1px, transparent 1px),
      linear-gradient(90deg, rgb(255 255 255 / .025) 1px, transparent 1px);
    background-size: 48px 48px;
  }

  .cta-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
  }

  .cta-blob--1 {
    width: 600px; height: 600px;
    top: -200px; left: -150px;
    background: radial-gradient(circle, rgba(168,168,60,0.35) 0%, transparent 70%);
  }

  .cta-blob--2 {
    width: 500px; height: 400px;
    bottom: -150px; right: -100px;
    background: radial-gradient(circle, rgba(30,60,180,0.45) 0%, transparent 70%);
  }

  /* ── Layout ──────────────────────────────────────────── */
  .cta-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-16);
    align-items: center;
  }

  @media (min-width: 1024px) {
    .cta-inner { grid-template-columns: 1.2fr 1fr; }
  }

  /* ── Badge ───────────────────────────────────────────── */
  .cta-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-4);
    background: rgb(227 227 166 / .12);
    color: var(--lime);
    border: 1px solid rgb(227 227 166 / .3);
    border-radius: var(--r-full);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: var(--sp-6);
  }

  /* ── Headline — explicit white, high contrast ────────── */
  .cta-headline {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 900;
    color: #ffffff;
    line-height: 1.1;
    letter-spacing: -0.04em;
    margin-bottom: var(--sp-6);
  }

  .cta-accent {
    color: #E3E3A6; /* explicit lime — never inherits white */
  }

  /* ── Body text ───────────────────────────────────────── */
  .cta-sub {
    font-size: 1.0625rem;
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.75;
    margin-bottom: var(--sp-8);
    max-width: 500px;
  }

  /* ── Buttons ─────────────────────────────────────────── */
  .cta-buttons {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-4);
    margin-bottom: var(--sp-8);
  }

  /* ── Trust items ─────────────────────────────────────── */
  .cta-trust {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3) var(--sp-5);
  }

  .cta-trust-item {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.55);
    font-weight: 500;
  }

  .cta-trust-item svg { color: #E3E3A6; flex-shrink: 0; }

  /* ── Pricing preview card ────────────────────────────── */
  .cta-visual { position: relative; }

  .pricing-preview {
    background: #ffffff;
    border-radius: var(--r-2xl);
    padding: var(--sp-6);
    box-shadow: 0 32px 64px -16px rgb(0 0 0 / .55);
  }

  .pp-header {
    text-align: center;
    padding-bottom: var(--sp-5);
    margin-bottom: var(--sp-5);
    border-bottom: 1px solid var(--slate-100);
  }

  .pp-label {
    display: block;
    font-size: 0.8125rem;
    color: var(--slate-400);
    font-weight: 600;
    margin-bottom: var(--sp-2);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .pp-price {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 2px;
    margin-bottom: var(--sp-2);
  }

  .pp-currency {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--navy);
  }

  .pp-amount {
    font-size: 3rem;
    font-weight: 900;
    color: var(--navy);
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .pp-period {
    font-size: 1rem;
    color: var(--slate-500);
    font-weight: 500;
  }

  .pp-sub {
    font-size: 0.8125rem;
    color: var(--slate-400);
    display: block;
  }

  .pp-tiers {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    margin-bottom: var(--sp-5);
  }

  .pp-tier {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--sp-3) var(--sp-4);
    border: 1px solid var(--slate-200);
    border-radius: var(--r-lg);
    gap: var(--sp-3);
  }

  .pp-tier--featured {
    border-color: var(--navy);
    background: var(--navy-50);
  }

  .pp-tier-left {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .pp-tier-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
  }

  .pp-tier-name {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text-dark);
  }

  .pp-tier-desc {
    font-size: 0.75rem;
    color: var(--slate-500);
  }

  .pp-tier-price {
    font-size: 0.9375rem;
    font-weight: 800;
    color: var(--navy);
    white-space: nowrap;
  }

  .pp-tier-badge {
    font-size: 0.625rem;
    font-weight: 800;
    background: var(--navy);
    color: var(--lime);
    padding: 2px 6px;
    border-radius: var(--r-full);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pp-cta-link {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-2);
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--navy);
    transition: color var(--t-fast);
  }

  .pp-cta-link:hover { color: var(--navy-700); }

  /* Neural AI badge */
  .neural-badge {
    position: absolute;
    bottom: -1.25rem;
    right: 0;
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-4);
    background: var(--lime);
    color: var(--navy);
    border-radius: var(--r-full);
    font-size: 0.75rem;
    font-weight: 700;
    box-shadow: var(--sh-md);
  }

  @media (max-width: 1023px) {
    .cta-headline { text-align: center; }
    .cta-sub      { max-width: 100%; text-align: center; }
    .cta-buttons  { justify-content: center; }
    .cta-trust    { justify-content: center; }
    .cta-badge    { display: flex; justify-content: center; }
  }
</style>
