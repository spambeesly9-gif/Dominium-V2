---
import BaseLayout from '../layouts/BaseLayout.astro';
import { articles } from '../data/insights.js';

const categories = [...new Set(articles.map(a => a.category))];
---

<BaseLayout
  title="Insights — Best Property Management Software Malta | Condominium Management Guides"
  description="Expert guides on property management software in Malta, block management best practices, and HOA administration. Practical advice for condominium administrators and block managers across Malta."
  keywords="best property management software Malta, how to manage apartment blocks Malta, property management guides Malta, condominium management insights Malta, automate property management Malta"
>

  <!-- Hero -->
  <section class="insights-hero">
    <div class="ih-bg" aria-hidden="true">
      <div class="ph-aurora"></div>
      <div class="ih-blob ih-blob--1"></div>
      <div class="ih-blob ih-blob--2"></div>
    </div>
    <div class="container ih-inner">
      <div class="badge" style="background:rgb(227 227 166/.12);color:var(--lime);border-color:rgb(227 227 166/.3);">Insights</div>
      <h1 class="ih-title">Property Management<br /><span class="ih-accent">Insights for Malta</span></h1>
      <p class="ih-sub">Expert guides, industry perspectives, and practical advice for condominium administrators and block managers across Malta.</p>
    </div>
  </section>

  <!-- Article grid -->
  <section class="section insights-section">
    <div class="container">
      <div class="insights-grid">
        {articles.map((article, i) => (
          <a href={`/insights/${article.slug}`} class={`article-card ${i === 0 ? 'article-card--featured' : ''}`}>
            <div class="article-meta">
              <span class="article-cat">{article.category}</span>
              <span class="article-read">{article.readTime}</span>
            </div>
            <h2 class="article-title">{article.title}</h2>
            <p class="article-excerpt">{article.excerpt}</p>
            <div class="article-footer">
              <span class="article-date">
                {new Date(article.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
              </span>
              <span class="article-read-more">
                Read article →
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="insights-cta">
    <div class="container" style="text-align:center">
      <h2>Ready to Modernise Your Condominium Management?</h2>
      <p>Book a free demo and see how Dominium fits your portfolio.</p>
      <a href="/contact#demo" class="btn btn--accent btn--lg">
        Book a Free Demo
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ────────────────────────────────────────────── */
  .insights-hero {
    background: var(--navy);
    position: relative;
    overflow: hidden;
    padding: var(--sp-20) 0 var(--sp-16);
    text-align: center;
  }
  .ih-bg { position: absolute; inset: 0; pointer-events: none; }
  .ih-blob { position: absolute; border-radius: 50%; filter: blur(110px); }
  .ih-blob--1 { width:600px;height:400px;top:-150px;left:-100px;background:radial-gradient(circle,rgba(168,168,60,.3) 0%,transparent 70%); }
  .ih-blob--2 { width:500px;height:400px;bottom:-100px;right:-100px;background:radial-gradient(circle,rgba(30,60,180,.4) 0%,transparent 70%); }
  .ih-inner { position: relative; z-index: 1; }
  .ih-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900;
    color: #ffffff;
    line-height: 1.12;
    letter-spacing: -0.035em;
    margin: var(--sp-5) 0;
  }
  .ih-accent { color: var(--lime); }
  .ih-sub {
    font-size: 1.0625rem;
    color: rgb(255 255 255 / .65);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.75;
  }

  /* ── Insights section ────────────────────────────────── */
  .insights-section { background: var(--bg-light); }

  .insights-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--sp-6);
  }

  @media (min-width: 1024px) {
    .insights-grid { grid-template-columns: repeat(3, 1fr); }
    .article-card--featured {
      grid-column: 1 / -1;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--sp-8);
    }
    .article-card--featured .article-title { font-size: 1.75rem; }
    .article-card--featured .article-excerpt { font-size: 1.0625rem; }
  }

  /* ── Article card ────────────────────────────────────── */
  .article-card {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    padding: var(--sp-8);
    background: var(--white);
    border: 1px solid var(--slate-200);
    border-radius: var(--r-2xl);
    text-decoration: none;
    transition: all var(--t-slow);
  }

  .article-card:hover {
    border-color: var(--navy-100);
    box-shadow: var(--sh-xl);
    transform: translateY(-3px);
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
  }

  .article-cat {
    display: inline-flex;
    padding: 3px 10px;
    background: var(--navy-50);
    color: var(--navy);
    border-radius: var(--r-full);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .article-read {
    font-size: 0.8125rem;
    color: var(--slate-400);
    font-weight: 500;
  }

  .article-title {
    font-size: 1.125rem;
    font-weight: 800;
    color: var(--text-dark);
    line-height: 1.3;
    letter-spacing: -0.02em;
    flex: 1;
  }

  .article-excerpt {
    font-size: 0.9375rem;
    color: var(--slate-500);
    line-height: 1.65;
  }

  .article-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--sp-4);
    border-top: 1px solid var(--slate-100);
    margin-top: auto;
  }

  .article-date {
    font-size: 0.8125rem;
    color: var(--slate-400);
    font-weight: 500;
  }

  .article-read-more {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--navy);
    transition: color var(--t-fast);
  }

  .article-card:hover .article-read-more { color: var(--navy-700); }

  /* ── CTA ─────────────────────────────────────────────── */
  .insights-cta {
    background: var(--navy);
    padding: var(--sp-16) 0;
  }
  .insights-cta h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 900;
    color: #ffffff;
    letter-spacing: -0.03em;
    margin-bottom: var(--sp-4);
  }
  .insights-cta p {
    font-size: 1.0625rem;
    color: rgb(255 255 255 / .65);
    margin-bottom: var(--sp-8);
  }
</style>
