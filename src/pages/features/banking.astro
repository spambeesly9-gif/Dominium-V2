---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCategoryBySlug } from '../../data/features.js';

const cat = getCategoryBySlug('banking');
---

<BaseLayout
  title="Virtual Banking — Property Payment System Malta | Rent Collection Software | Dominium"
  description="Each condominium block gets its own virtual IBAN via Fyorin. Dominium's property payment system automates rent collection and service charge payments for Malta's block managers — the complete rent collection software for HOAs."
  keywords="property payment system Malta, rent collection software Malta, virtual IBAN condominium Malta, property banking software Malta, automated payments condominium Malta"
>
  <section class="cat-hero">
    <div class="ch-bg" aria-hidden="true">
      <div class="ph-aurora"></div>
      <div class="ch-blob ch-blob--1"></div>
      <div class="ch-blob ch-blob--2"></div>
    </div>
    <div class="container ch-inner">
      <a href="/features" class="ch-breadcrumb">← All Features</a>
      <div class="badge" style="background:rgb(227 227 166/.12);color:var(--lime);border-color:rgb(227 227 166/.3);">{cat.title}</div>
      <h1 class="ch-title">{cat.title}</h1>
      <p class="ch-sub">{cat.tagline}</p>
    </div>
  </section>

  <!-- Fyorin logo bar -->
  <section class="fyorin-bar">
    <div class="container fyorin-inner">
      <span class="fyorin-label">Powered by</span>
      <img src="/Fyorin logo.webp" alt="Fyorin" class="fyorin-logo" />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sf-list">
        {cat.subFeatures.map((f, i) => (
          <div class={`sf-row ${i % 2 === 1 ? 'sf-row--flip' : ''}`}>
            <div class="sf-content">
              <h2 class="sf-title">{f.title}</h2>
              <p class="sf-desc">{f.description}</p>
              <ul class="sf-caps">
                {f.capabilities.map(c => (
                  <li class="sf-cap">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    {c}
                  </li>
                ))}
              </ul>
              <a href={`/features/banking/${f.slug}`} class="sf-link">
                Learn more <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="sf-visual">
              <div class="sf-frame">
                <div class="sf-chrome"><div class="sf-dots"><span style="background:#FF5F57"></span><span style="background:#FFBD2E"></span><span style="background:#27C93F"></span></div></div>
                <div class="sf-body"><img src={f.image} alt={f.imageAlt} loading="lazy" /></div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cat-cta">
    <div class="container" style="text-align:center">
      <h2>Give Every Block Its Own Bank Account</h2>
      <p>See how Fyorin virtual banking works within Dominium.</p>
      <a href="/contact#demo" class="btn btn--accent btn--lg">Book a Free Demo</a>
    </div>
  </section>
</BaseLayout>

<style>
  .cat-hero { background:var(--navy);position:relative;overflow:hidden;padding:var(--sp-16) 0 var(--sp-12);text-align:center; }
  .ch-bg { position:absolute;inset:0;pointer-events:none; }
  .ch-blob { position:absolute;border-radius:50%;filter:blur(110px); }
  .ch-blob--1 { width:500px;height:400px;top:-150px;left:-100px;background:radial-gradient(circle,rgba(168,168,60,.25) 0%,transparent 70%); }
  .ch-blob--2 { width:400px;height:300px;bottom:-80px;right:-80px;background:radial-gradient(circle,rgba(30,60,180,.35) 0%,transparent 70%); }
  .ch-inner { position:relative;z-index:1; }
  .ch-breadcrumb { display:inline-flex;align-items:center;gap:var(--sp-2);font-size:.875rem;color:rgb(255 255 255/.5);margin-bottom:var(--sp-5);transition:color var(--t-fast); }
  .ch-breadcrumb:hover { color:var(--lime); }
  .ch-title { font-size:clamp(2rem,5vw,3rem);font-weight:900;color:#ffffff;letter-spacing:-0.035em;margin:var(--sp-4) 0; }
  .ch-sub { font-size:1.0625rem;color:rgb(255 255 255/.65);max-width:560px;margin:0 auto;line-height:1.75; }
  .fyorin-bar { background:var(--bg-light);border-top:1px solid var(--slate-200);border-bottom:1px solid var(--slate-200);padding:var(--sp-5) 0; }
  .fyorin-inner { display:flex;align-items:center;justify-content:center;gap:var(--sp-4); }
  .fyorin-label { font-size:.875rem;color:var(--slate-400);font-weight:600; }
  .fyorin-logo { height:30px;width:auto;object-fit:contain; }
  .sf-list { display:flex;flex-direction:column;gap:var(--sp-24); }
  .sf-row { display:grid;grid-template-columns:1fr;gap:var(--sp-10);align-items:center; }
  @media (min-width:768px) { .sf-row { grid-template-columns:1fr 1fr; } .sf-row--flip .sf-visual { order:-1; } }
  .sf-title { font-size:clamp(1.5rem,3vw,2rem);font-weight:800;color:var(--text-dark);letter-spacing:-0.03em;margin-bottom:var(--sp-4); }
  .sf-desc { font-size:1rem;color:var(--slate-600);line-height:1.75;margin-bottom:var(--sp-5); }
  .sf-caps { display:flex;flex-direction:column;gap:var(--sp-3);margin-bottom:var(--sp-6); }
  .sf-cap { display:flex;align-items:center;gap:var(--sp-3);font-size:.9375rem;color:var(--slate-700);font-weight:500; }
  .sf-cap svg { color:var(--navy);background:var(--lime);border-radius:50%;padding:2px;width:20px;height:20px;flex-shrink:0; }
  .sf-link { display:inline-flex;align-items:center;gap:var(--sp-2);font-size:.9375rem;font-weight:700;color:var(--navy);transition:color var(--t-fast); }
  .sf-link:hover { color:var(--navy-700); }
  .sf-frame { border-radius:var(--r-2xl);overflow:hidden;border:1px solid var(--slate-200);box-shadow:var(--sh-xl);background:var(--white); }
  .sf-chrome { display:flex;align-items:center;padding:.5rem var(--sp-4);background:var(--slate-100);border-bottom:1px solid var(--slate-200); }
  .sf-dots { display:flex;gap:5px; }
  .sf-dots span { width:10px;height:10px;border-radius:50%;display:block; }
  .sf-body img { width:100%;height:auto;display:block; }
  .cat-cta { background:var(--navy);padding:var(--sp-16) 0; }
  .cat-cta h2 { font-size:clamp(1.75rem,4vw,2.5rem);font-weight:900;color:#ffffff;letter-spacing:-0.03em;margin-bottom:var(--sp-4); }
  .cat-cta p { font-size:1.0625rem;color:rgb(255 255 255/.65);margin-bottom:var(--sp-8); }
</style>
