---
import BaseLayout from '../layouts/BaseLayout.astro';

const plans = [
  {
    name: 'Beginner',
    price: 300,
    units: 'Up to 300 units',
    description: 'Perfect for smaller administrators managing a single block or a handful of condominiums.',
    support: 'Email support',
    features: [
      'Unlimited condominiums',
      'All unit & client management',
      'Contribution fee management',
      'Work requests & maintenance',
      'Financial entries & bank tracking',
      'Client communications',
      'Document & file management',
      'Cleaning & inspection reports',
      'Resident client portal',
      'Issue reporting (client portal)',
      'Online fee payments (client portal)',
      'Email support',
    ],
    cta: 'Get Started',
    featured: false,
  },
  {
    name: 'Professional',
    price: 500,
    units: 'Up to 800 units',
    description: 'The most popular plan for growing portfolios. Includes accounting integrations and priority support.',
    support: 'Priority WhatsApp & call support',
    features: [
      'Everything in Beginner',
      'Xero accounting integration',
      'QuickBooks integration',
      'Zoho Books integration',
      'Automated accounting sync',
      'Priority WhatsApp support',
      'Priority phone support',
    ],
    cta: 'Get Started',
    featured: true,
  },
  {
    name: 'Enterprise',
    price: 800,
    units: 'Up to 2,000 units',
    description: 'For large property management companies running complex multi-block portfolios with banking needs.',
    support: 'Weekend support included',
    features: [
      'Everything in Professional',
      'Fyorin virtual IBAN integration',
      'Automated receivables',
      'Automated payables',
      'Virtual banking per condominium',
      'Weekend support',
      'Dedicated account manager',
    ],
    cta: 'Get Started',
    featured: false,
  },
];

const allFeatures = [
  { name: 'Condominium management',       beginner: true,  pro: true,  ent: true  },
  { name: 'Unit & client management',     beginner: true,  pro: true,  ent: true  },
  { name: 'Contribution fee management',  beginner: true,  pro: true,  ent: true  },
  { name: 'Maintenance & work requests',  beginner: true,  pro: true,  ent: true  },
  { name: 'Financial entries & tracking', beginner: true,  pro: true,  ent: true  },
  { name: 'Client communications',        beginner: true,  pro: true,  ent: true  },
  { name: 'Document & file management',   beginner: true,  pro: true,  ent: true  },
  { name: 'Cleaning & inspection reports',beginner: true,  pro: true,  ent: true  },
  { name: 'Resident client portal',       beginner: true,  pro: true,  ent: true  },
  { name: 'Issue reporting (portal)',     beginner: true,  pro: true,  ent: true  },
  { name: 'Online fee payments (portal)', beginner: true,  pro: true,  ent: true  },
  { name: 'Xero integration',            beginner: false, pro: true,  ent: true  },
  { name: 'QuickBooks integration',      beginner: false, pro: true,  ent: true  },
  { name: 'Zoho Books integration',      beginner: false, pro: true,  ent: true  },
  { name: 'Fyorin virtual IBAN',         beginner: false, pro: false, ent: true  },
  { name: 'Automated receivables',       beginner: false, pro: false, ent: true  },
  { name: 'Automated payables',          beginner: false, pro: false, ent: true  },
  { name: 'Email support',               beginner: true,  pro: true,  ent: true  },
  { name: 'WhatsApp & call support',     beginner: false, pro: true,  ent: true  },
  { name: 'Weekend support',             beginner: false, pro: false, ent: true  },
];

const faqs = [
  {
    q: 'Is there a setup fee?',
    a: 'No. There is no setup fee on any Dominium plan. You only pay the monthly subscription starting from the day you go live.',
  },
  {
    q: 'Can I cancel anytime?',
    a: 'Yes. All Dominium plans are month-to-month with no long-term contracts. You can cancel at any time with no penalty.',
  },
  {
    q: 'What happens if I exceed my unit limit?',
    a: 'Our team will reach out to discuss upgrading to the next plan. We never cut off your access — we work with you to find the right solution.',
  },
  {
    q: 'Is the mobile app included in the subscription?',
    a: 'The mobile app is an optional add-on at a one-time cost of €1,750. It gives your residents a native iOS and Android experience with push notifications.',
  },
  {
    q: 'Do you offer support for onboarding?',
    a: 'Yes. All plans include dedicated onboarding support. Our team will help you set up your condominiums, import data, and go live smoothly.',
  },
  {
    q: 'Which accounting software does Dominium integrate with?',
    a: 'Dominium integrates with Xero, QuickBooks, and Zoho Books on the Professional and Enterprise plans. Fyorin virtual banking is available on Enterprise.',
  },
];
---

<BaseLayout
  title="Pricing — Property Management Software Malta | Condominium Software Plans | Dominium"
  description="Transparent pricing for Malta's leading condominium management software. No setup fees, no hidden costs. Choose the right property management system plan for your portfolio — pay monthly, cancel anytime."
  keywords="property management software pricing Malta, condominium management software cost Malta, block management software pricing, HOA software Malta pricing, best property management software Malta"
>

  <!-- Page hero -->
  <section class="page-hero">
    <div class="page-hero-bg" aria-hidden="true">
      <div class="ph-aurora"></div>
      <div class="ph-grid"></div>
      <div class="ph-blob"></div>
    </div>
    <div class="container ph-inner">
      <div class="badge" style="background:rgb(255 255 255/.1);color:var(--lime);border-color:rgb(227 227 166/.25);margin-bottom:var(--sp-5);">
        Simple, Transparent Pricing
      </div>
      <h1 class="ph-title">No Setup Fees.<br /><span class="ph-title--accent">No Hidden Costs.</span></h1>
      <p class="ph-sub">Simple, transparent plans for Malta's block managers and HOAs. Pay monthly, cancel anytime. Every plan includes the full admin panel and resident portal — no features locked behind a paywall.</p>
    </div>
  </section>

  <!-- Pricing cards -->
  <section class="section pricing-section">
    <div class="container">
      <div class="pricing-grid">
        {plans.map(plan => (
          <div class={`plan-card ${plan.featured ? 'plan-card--featured' : ''}`}>
            {plan.featured && (
              <div class="plan-badge">Most Popular</div>
            )}

            <div class="plan-header">
              <h2 class="plan-name">{plan.name}</h2>
              <p class="plan-desc">{plan.description}</p>
            </div>

            <div class="plan-price">
              <span class="plan-currency">€</span>
              <span class="plan-amount">{plan.price}</span>
              <span class="plan-period">/month</span>
            </div>

            <div class="plan-units">{plan.units}</div>

            <a
              href="/contact#demo"
              class={`plan-cta ${plan.featured ? 'plan-cta--featured' : ''}`}
            >
              {plan.cta}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>

            <ul class="plan-features">
              {plan.features.map((f, i) => (
                <li class={`plan-feature ${i === 0 && plan.name !== 'Beginner' ? 'plan-feature--inherit' : ''}`}>
                  {i === 0 && plan.name !== 'Beginner' ? (
                    <>
                      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                      {f}
                    </>
                  ) : (
                    <>
                      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                      {f}
                    </>
                  )}
                </li>
              ))}
            </ul>

            <div class="plan-support">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.1 10.8a19.79 19.79 0 01-3.07-8.67A2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92v2z"/></svg>
              {plan.support}
            </div>
          </div>
        ))}
      </div>

      <!-- Guarantees row -->
      <div class="guarantees">
        <div class="guarantee-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          No setup fee
        </div>
        <div class="guarantee-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Cancel anytime
        </div>
        <div class="guarantee-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          No hidden costs
        </div>
        <div class="guarantee-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Dedicated onboarding
        </div>
      </div>
    </div>
  </section>

  <!-- Mobile app add-on -->
  <section class="addon-section">
    <div class="container">
      <div class="addon-card">
        <div class="addon-left">
          <div class="addon-tag">Optional Add-on</div>
          <h2 class="addon-title">Mobile App</h2>
          <p class="addon-desc">Give your residents a native iOS and Android experience. The Dominium mobile app enables push notifications, issue reporting, and balance visibility — all from their smartphone.</p>
          <ul class="addon-features">
            <li>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Available on Google Play & Apple App Store
            </li>
            <li>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Push notifications for fees, updates, and maintenance
            </li>
            <li>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Full client portal features in a native app
            </li>
            <li>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              One-time cost — no recurring fee
            </li>
          </ul>
          <a href="/contact#demo" class="btn btn--primary" style="margin-top:var(--sp-6);">Ask About the App</a>
        </div>
        <div class="addon-right">
          <div class="addon-price-box">
            <span class="addon-price-label">One-time fee</span>
            <div class="addon-price">
              <span class="addon-currency">€</span>
              <span class="addon-amount">1,750</span>
            </div>
            <span class="addon-price-note">No recurring charge · Works with any plan</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature comparison table -->
  <section class="section comparison-section">
    <div class="container">
      <div class="section-header">
        <div class="badge">Feature Comparison</div>
        <h2>What's Included in Each Plan</h2>
      </div>

      <div class="comparison-table-wrap">
        <table class="comparison-table">
          <thead>
            <tr>
              <th class="col-feature">Feature</th>
              <th class="col-plan">Beginner</th>
              <th class="col-plan col-plan--featured">Professional</th>
              <th class="col-plan">Enterprise</th>
            </tr>
            <tr class="price-row">
              <td></td>
              <td class="col-price">€300/mo</td>
              <td class="col-price col-price--featured">€500/mo</td>
              <td class="col-price">€800/mo</td>
            </tr>
          </thead>
          <tbody>
            {allFeatures.map(f => (
              <tr>
                <td class="feat-name">{f.name}</td>
                <td class="feat-check">{f.beginner ? <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="check-yes" aria-label="Included"><polyline points="20 6 9 17 4 12"/></svg> : <span class="check-no" aria-label="Not included">—</span>}</td>
                <td class="feat-check feat-check--featured">{f.pro ? <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="check-yes" aria-label="Included"><polyline points="20 6 9 17 4 12"/></svg> : <span class="check-no" aria-label="Not included">—</span>}</td>
                <td class="feat-check">{f.ent ? <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="check-yes" aria-label="Included"><polyline points="20 6 9 17 4 12"/></svg> : <span class="check-no" aria-label="Not included">—</span>}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section faq-section">
    <div class="container">
      <div class="section-header">
        <div class="badge">FAQ</div>
        <h2>Frequently Asked Questions</h2>
      </div>

      <div class="faq-grid">
        {faqs.map(faq => (
          <div class="faq-item">
            <h3 class="faq-q">{faq.q}</h3>
            <p class="faq-a">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="pricing-cta">
    <div class="container pricing-cta-inner">
      <h2 class="pricing-cta-title">Not Sure Which Plan Is Right for You?</h2>
      <p class="pricing-cta-sub">Book a free 30-minute demo and we'll recommend the best plan for your portfolio size and needs.</p>
      <div class="pricing-cta-btns">
        <a href="/contact#demo" class="btn btn--accent btn--lg">Book a Free Demo</a>
        <a href="/contact" class="btn btn--ghost-light btn--lg">Talk to Us</a>
      </div>
    </div>
  </section>

</BaseLayout>

<script is:inline type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": f.a
    }
  }))
})} />

<style>
  /* ── Page hero ───────────────────────────────────────── */
  .page-hero {
    background: var(--navy);
    position: relative;
    overflow: hidden;
    padding: var(--sp-20) 0 var(--sp-16);
  }

  .page-hero-bg { position: absolute; inset: 0; pointer-events: none; }

  .ph-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgb(255 255 255 / .035) 1px, transparent 1px),
      linear-gradient(90deg, rgb(255 255 255 / .035) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  .ph-blob {
    position: absolute; border-radius: 50%; filter: blur(100px);
    width: 500px; height: 400px; top: -150px; right: -100px;
    background: radial-gradient(circle, rgb(227 227 166 / .1) 0%, transparent 70%);
  }

  .ph-inner {
    position: relative; z-index: 1;
    max-width: 700px;
    text-align: center;
    margin: 0 auto;
  }

  .ph-title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 900;
    color: var(--white);
    line-height: 1.1;
    letter-spacing: -0.04em;
    margin-bottom: var(--sp-5);
  }

  .ph-title--accent { color: var(--lime); }

  .ph-sub {
    font-size: 1.125rem;
    color: rgb(255 255 255 / .65);
    line-height: 1.7;
  }

  /* ── Pricing cards ───────────────────────────────────── */
  .pricing-section { background: var(--white); }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--sp-6);
    align-items: start;
    margin-bottom: var(--sp-10);
  }

  @media (min-width: 1024px) {
    .pricing-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .plan-card {
    background: var(--white);
    border: 1px solid var(--slate-200);
    border-radius: var(--r-2xl);
    padding: var(--sp-8);
    position: relative;
    transition: all var(--t-slow);
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }

  .plan-card:hover {
    border-color: var(--navy-100);
    box-shadow: var(--sh-xl);
    transform: translateY(-3px);
  }

  .plan-card--featured {
    border-color: var(--navy);
    box-shadow: var(--sh-xl);
  }

  .plan-badge {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--navy);
    color: var(--lime);
    font-size: 0.75rem;
    font-weight: 800;
    padding: var(--sp-1) var(--sp-4);
    border-radius: var(--r-full);
    white-space: nowrap;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .plan-header { display: flex; flex-direction: column; gap: var(--sp-2); }

  .plan-name {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--text-dark);
    letter-spacing: -0.02em;
  }

  .plan-desc {
    font-size: 0.9rem;
    color: var(--slate-500);
    line-height: 1.6;
  }

  .plan-price {
    display: flex;
    align-items: baseline;
    gap: 2px;
  }

  .plan-currency { font-size: 1.5rem; font-weight: 700; color: var(--navy); }
  .plan-amount   { font-size: 3.5rem; font-weight: 900; color: var(--navy); letter-spacing: -0.04em; line-height: 1; }
  .plan-period   { font-size: 1rem; color: var(--slate-500); font-weight: 500; margin-left: 2px; }

  .plan-units {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--navy);
    background: var(--navy-50);
    border: 1px solid var(--navy-100);
    padding: var(--sp-2) var(--sp-4);
    border-radius: var(--r-full);
    display: inline-flex;
    width: fit-content;
  }

  .plan-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-2);
    padding: 0.875rem var(--sp-6);
    border-radius: var(--r-lg);
    font-size: 1rem;
    font-weight: 700;
    background: var(--bg-light);
    color: var(--navy);
    border: 2px solid var(--navy-100);
    transition: all var(--t-base);
  }

  .plan-cta:hover {
    background: var(--navy-50);
    border-color: var(--navy);
    transform: translateY(-1px);
  }

  .plan-cta--featured {
    background: var(--navy);
    color: var(--lime);
    border-color: var(--navy);
  }

  .plan-cta--featured:hover {
    background: var(--navy-700);
    border-color: var(--navy-700);
    color: var(--lime);
  }

  .plan-features {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding-top: var(--sp-2);
    border-top: 1px solid var(--slate-100);
    flex: 1;
  }

  .plan-feature {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    font-size: 0.9rem;
    color: var(--slate-700);
  }

  .plan-feature svg { color: var(--success); flex-shrink: 0; }

  .plan-feature--inherit { font-weight: 700; color: var(--navy); }

  .plan-support {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: 0.8125rem;
    color: var(--slate-500);
    padding-top: var(--sp-4);
    border-top: 1px solid var(--slate-100);
    font-weight: 500;
  }

  /* ── Guarantees ──────────────────────────────────────── */
  .guarantees {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--sp-6) var(--sp-8);
    padding: var(--sp-6);
    background: var(--navy-50);
    border: 1px solid var(--navy-100);
    border-radius: var(--r-2xl);
  }

  .guarantee-item {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--navy);
  }

  .guarantee-item svg { color: var(--success); }

  /* ── Addon section ───────────────────────────────────── */
  .addon-section {
    background: var(--bg-light);
    border-top: 1px solid var(--slate-200);
    border-bottom: 1px solid var(--slate-200);
    padding: var(--sp-16) 0;
  }

  .addon-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-10);
    align-items: center;
    background: var(--white);
    border: 1px solid var(--slate-200);
    border-radius: var(--r-2xl);
    padding: var(--sp-10);
  }

  @media (min-width: 768px) {
    .addon-card { grid-template-columns: 1fr auto; }
  }

  .addon-tag {
    display: inline-flex;
    padding: var(--sp-1) var(--sp-3);
    background: var(--lime-light);
    color: #5a5a00;
    border: 1px solid var(--lime);
    border-radius: var(--r-full);
    font-size: 0.6875rem;
    font-weight: 800;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    margin-bottom: var(--sp-4);
  }

  .addon-title {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 900;
    color: var(--text-dark);
    letter-spacing: -0.04em;
    margin-bottom: var(--sp-4);
  }

  .addon-desc {
    font-size: 1rem;
    color: var(--slate-600);
    line-height: 1.75;
    margin-bottom: var(--sp-5);
    max-width: 520px;
  }

  .addon-features {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .addon-features li {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    font-size: 0.9375rem;
    color: var(--slate-700);
    font-weight: 500;
  }

  .addon-features svg { color: var(--success); flex-shrink: 0; }

  .addon-price-box {
    text-align: center;
    padding: var(--sp-8);
    background: var(--navy);
    border-radius: var(--r-2xl);
    min-width: 200px;
  }

  .addon-price-label {
    display: block;
    font-size: 0.8125rem;
    color: rgb(255 255 255 / .55);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--sp-3);
  }

  .addon-price {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 2px;
